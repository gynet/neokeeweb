{
  "name": "neokeeweb",
  "version": "0.1.0",
  "private": true,
  "description": "Modern KeePass web client - TypeScript monorepo",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @neokeeweb/core dev",
    "build": "bun run --filter @neokeeweb/db build && bun run --filter @neokeeweb/core build",
    "test": "bun run --filter @neokeeweb/db build && bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "test:db": "bun run --filter @neokeeweb/db test",
    "test:core": "bun run --filter @neokeeweb/core test",
    "test:extension": "bun run --filter @neokeeweb/extension test",
    "test:e2e": "bunx playwright test",
    "test:e2e:ext": "cd packages/extension && bunx playwright test",
    "report": "bunx playwright show-report"
  },
  "author": "gynet",
  "repository": {
    "type": "git",
    "url": "https://github.com/gynet/neokeeweb.git"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
