{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "allowJs": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "paths": {
      "const/*": ["./app/scripts/const/*"],
      "util/*": ["./app/scripts/util/*"],
      "models/*": ["./app/scripts/models/*"],
      "framework/*": ["./app/scripts/framework/*"],
      "comp/*": ["./app/scripts/comp/*"],
      "collections/*": ["./app/scripts/collections/*"],
      "storage": ["./app/scripts/storage/index.ts"],
      "storage/*": ["./app/scripts/storage/*"],
      "hbs": ["./node_modules/handlebars/types/index.d.ts"],
      "locales/*": ["./app/resources/locales/*"]
    }
  },
  "include": [
    "app/scripts/const/**/*.ts",
    "app/scripts/util/**/*.ts",
    "app/scripts/models/**/*.ts",
    "app/scripts/storage/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
