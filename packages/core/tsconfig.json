{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "allowJs": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "paths": {
      "const/*": ["./app/scripts/const/*"],
      "util/*": ["./app/scripts/util/*"],
      "models/*": ["./app/scripts/models/*"],
      "framework/*": ["./app/scripts/framework/*"],
      "comp/*": ["./app/scripts/comp/*"],
      "collections/*": ["./app/scripts/collections/*"],
      "storage": ["./app/scripts/storage/index.js"],
      "hbs-helpers/*": ["./app/scripts/hbs-helpers/*"],
      "presenters/*": ["./app/scripts/presenters/*"],
      "hbs": ["./app/scripts/types.d.ts"],
      "locales/*": ["./app/resources/locales/*"]
    }
  },
  "include": [
    "app/scripts/types.d.ts",
    "app/scripts/const/**/*.ts",
    "app/scripts/util/**/*.ts",
    "app/scripts/models/**/*.ts",
    "app/scripts/framework/**/*.ts",
    "app/scripts/collections/**/*.ts",
    "app/scripts/hbs-helpers/**/*.ts",
    "app/scripts/presenters/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
