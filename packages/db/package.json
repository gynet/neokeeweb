{
    "name": "@neokeeweb/db",
    "version": "2.2.0",
    "description": "Kdbx KeePass database reader for web",
    "main": "dist/kdbxweb.js",
    "private": false,
    "types": "dist/types/index.d.ts",
    "homepage": "https://keeweb.info",
    "repository": {
        "type": "git",
        "url": "https://github.com/keeweb/kdbxweb.git"
    },
    "author": {
        "name": "Antelle",
        "email": "keeweb@keeweb.info",
        "url": "https://antelle.net"
    },
    "engines": {
        "node": "^18.18.0"
    },
    "license": "MIT",
    "readme": "README.md",
    "funding": {
        "type": "github",
        "url": "https://github.com/sponsors/antelle"
    },
    "scripts": {
        "test": "bun test",
        "start": "bun run lint && bun run build",
        "tsc": "tsc",
        "lint": "eslint lib test conf scripts",
        "build": "bun run clean && bun run pack:dist-debug && bun run pack:dist-prod",
        "clean": "rimraf dist",
        "pack:dist-prod": "webpack --progress --mode=production --config conf/webpack.config.ts --mode production",
        "pack:dist-debug": "webpack --progress --mode=development --devtool source-map --config conf/webpack.config.ts --mode development",
        "script:dump-header": "bun run scripts/dump-header",
        "script:kdbx-size-profiler": "bun run scripts/kdbx-size-profiler",
        "script:kdbx-to-xml": "bun run scripts/kdbx-to-xml",
        "script:make-big-files": "bun run scripts/make-big-files",
        "script:save-perf-test": "bun run scripts/save-perf-test"
    },
    "keywords": [
        "kdbx",
        "keepass"
    ],
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^8.18.1",
        "@typescript-eslint/parser": "^8.18.1",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-n": "17.15.0",
        "eslint-plugin-prettier": "^5.2.1",
        "eslint-plugin-promise": "^7.2.1",
        "prettier": "^3.4.2",
        "prettier-eslint": "^16.3.0",
        "rimraf": "^3.0.2",
        "terser-webpack-plugin": "^5.2.3",
        "ts-loader": "^9.2.5",
        "ts-node": "^10.2.1",
        "typescript": "^5.7.2",
        "webpack": "^5.97.1",
        "webpack-cli": "^6.0.1"
    },
    "dependencies": {
        "@xmldom/xmldom": "^0.8.10",
        "fflate": "^0.7.1"
    }
}
